{
  "ReverseProxy": {
    "Routes": {
      "reportRoute": {
        "ClusterId": "reportCluster",
        "Match": {
          "Path": "/api/report/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "reportCluster": {
        "Destinations": {
          "reportService": {
            "Address": "http://reportservice"
          }
        }
      }
    }
  }
}