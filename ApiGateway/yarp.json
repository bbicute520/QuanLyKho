{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },
      "supplier-route": {
        "ClusterId": "supplier-cluster",
        "Match": {
          "Path": "/api/supplier/{**catch-all}"
        }
      },
      "report-route": {
        "ClusterId": "report-cluster",
        "Match": {
          "Path": "/api/report/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://auth-service"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-service": {
            "Address": "http://inventory-service"
          }
        }
      },
      "supplier-cluster": {
        "Destinations": {
          "supplier-service": {
            "Address": "http://supplier-service"
          }
        }
      },
      "report-cluster": {
        "Destinations": {
          "report-service": {
            "Address": "http://report-service"
          }
        }
      }
    }
  }
}